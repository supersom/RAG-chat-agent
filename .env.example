# ── LLM Provider ─────────────────────────────────────────────────────────────
# Uncomment the block for the provider you want to use.
# LiteLLM infers the provider from the model name — no extra config needed.

# OpenAI
OPENAI_API_KEY=sk-proj-...
NEXT_PUBLIC_MODELS=gpt-4o-mini:GPT-4o Mini,gpt-4o:GPT-4o

# Anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# NEXT_PUBLIC_MODELS=claude-haiku-4-5-20251001:Claude Haiku 4.5,claude-sonnet-4-6:Claude Sonnet 4.6

# OpenRouter
# OPENROUTER_API_KEY=sk-or-...
# NEXT_PUBLIC_MODELS=openrouter/gpt-4o-mini:GPT-4o Mini,openrouter/anthropic/claude-sonnet-4-6:Claude Sonnet 4.6

# ── AWS (for Bedrock Knowledge Base) ─────────────────────────────────────────
BAWS_ACCESS_KEY_ID=your-access-key-id
BAWS_SECRET_ACCESS_KEY=your-secret-access-key

# ── Knowledge Base ────────────────────────────────────────────────────────────
NEXT_PUBLIC_KNOWLEDGE_BASE_ID=your-bedrock-kb-id

# ── App ───────────────────────────────────────────────────────────────────────
COMPANY_NAME=Your Company

# ── Auth & Multi-tenancy ──────────────────────────────────────────────────────
AUTH_SECRET=your-auth-secret # secret used to sign admin/end-user session tokens
TENANT_JWT_SECRET=your-tenant-jwt-secret # secret used to sign/verify tenant-scoped JWTs
DYNAMODB_TENANTS_TABLE=your-tenants-table-name # DynamoDB table name for the Tenants table
DYNAMODB_USERS_TABLE=your-users-table-name # DynamoDB table name for the Users table
